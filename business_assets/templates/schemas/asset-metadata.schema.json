{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssetMetadata",
  "description": "Metadata for a single media asset. Used by website, CMS import, and SEO pipelines.",
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "altText",
    "caption",
    "seoFilename",
    "category",
    "copyright",
    "orientation",
    "resolution",
    "dateAdded",
    "originalPath",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "altText": { "type": "string" },
    "caption": { "type": "string" },
    "seoFilename": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["hero", "gallery", "drone", "layout", "brochure", "logo", "approval", "document", "social", "stock", "other"]
    },
    "copyright": { "type": "string" },
    "orientation": { "type": "string", "enum": ["landscape", "portrait", "square", "unknown"] },
    "resolution": {
      "type": "object",
      "properties": {
        "width": { "type": ["integer", "null"] },
        "height": { "type": ["integer", "null"] }
      }
    },
    "dateAdded": { "type": "string", "format": "date" },
    "originalPath": { "type": "string" },
    "generatedPath": { "type": ["string", "null"] },
    "mimeType": { "type": ["string", "null"] },
    "sizeBytes": { "type": ["integer", "null"] },
    "status": { "type": "string", "enum": ["pending_migration", "active", "generated", "deprecated"] }
  }
}
